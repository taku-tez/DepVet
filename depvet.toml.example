# depvet.toml — DepVet configuration file
# Copy to depvet.toml and customize.

[llm]
provider = "claude"                      # claude | openai | vertex-claude | vertex-gemini
model = "claude-sonnet-4-20250514"
api_key_env = "ANTHROPIC_API_KEY"        # env var name holding the API key
triage_model = "claude-haiku-4-5-20251001"  # Cheaper model for Stage 1 triage
max_tokens = 4096
timeout = 60                             # seconds

[monitor]
interval = 300                           # Polling interval (seconds)
ecosystems = ["pypi", "npm"]             # pypi | npm | go | cargo | maven
max_concurrent_analyses = 4              # Max parallel LLM analyses per cycle
queue_max_size = 100                     # Max releases per cycle (0 = unlimited)

[watchlist]
sources = ["explicit", "top_n"]          # explicit | top_n | sbom
sbom_path = "./sbom.cyclonedx.json"      # Auto-import when "sbom" in sources
sbom_format = "cyclonedx"                # cyclonedx | spdx
top_n_pypi = 1000
top_n_npm = 1000
refresh_interval = 86400                 # Top-N refresh interval (seconds)

[diff]
max_chunk_tokens = 8000
skip_test_files = true
skip_docs = true
priority_files = [
    "setup.py", "pyproject.toml", "package.json",
    "go.mod", "go.sum", "Cargo.toml", "Cargo.lock",
    "__init__.py", "index.js", "auth.py",
]

[alert]
min_severity = "MEDIUM"                  # NONE | LOW | MEDIUM | HIGH | CRITICAL
slack_webhook_env = "DEPVET_SLACK_WEBHOOK"
webhook_url = ""                         # Generic webhook endpoint (must be http:// or https://)
webhook_secret_env = "DEPVET_WEBHOOK_SECRET"  # HMAC-SHA256 signing secret env var
dlq_path = ".depvet_dlq.yaml"           # Dead letter queue for failed alerts

[state]
path = "./depvet_state.yaml"             # Polling state persistence

[securify]
enabled = false
endpoint = "https://api.securify.example.com"
api_key_env = "SECURIFY_API_KEY"
